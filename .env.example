# Database
DATABASE_URL=postgresql+psycopg2://postgres:your_secure_password_here@localhost:5432/kids_bible_db
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=kids_bible_db
# Production example:
# DATABASE_URL=postgresql+psycopg2://kids_user:strong_password@your-oracle-vm-public-ip:5432/kids_bible_db

# Backend
SECRET_KEY=your-secret-key-change-in-production-use-strong-key
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-netlify-site.netlify.app,https://your-vercel-site.vercel.app
ALLOWED_HOSTS=localhost,127.0.0.1,your-koyeb-service.koyeb.app
# Azure Storage
AZURE_STORAGE_ACCOUNT_NAME=your_storage_account
AZURE_STORAGE_ACCOUNT_KEY=your_storage_key

# Frontend
VITE_API_BASE_URL=https://your-koyeb-service.koyeb.app/api/v1
