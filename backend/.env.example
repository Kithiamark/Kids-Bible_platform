# Application Settings
APP_NAME=Kids Delight Learning Platform
ENVIRONMENT=development
DEBUG=True
API_VERSION=v1

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql+psycopg2://username:password@localhost:5432/kids_bible_db

# Production example: PostgreSQL hosted on Oracle Cloud VM, backend on Koyeb
# DATABASE_URL=postgresql+psycopg2://kids_user:strong_password@your-oracle-vm-public-ip:5432/kids_bible_db

# Optional object storage
AZURE_STORAGE_ACCOUNT_NAME=your_storage_account
AZURE_STORAGE_ACCOUNT_KEY=your_storage_key
AZURE_STORAGE_CONTAINER_NAME=media

# CORS and hosts
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-netlify-site.netlify.app,https://your-vercel-site.vercel.app
ALLOWED_HOSTS=localhost,127.0.0.1,your-koyeb-service.koyeb.app

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
